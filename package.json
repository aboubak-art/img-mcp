{
  "name": "img-mcp",
  "version": "1.3.0",
  "description": "An open-source MCP server for AI image generation. Supports Google's Nano Banana models via the Gemini API.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "img-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "prepublishOnly": "npm run lint && npm run build && npm test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "website:build": "npm run docs:build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "image-generation",
    "ai",
    "google",
    "nano-banana",
    "gemini"
  ],
  "author": "Aboubakar Sidik Faha <me@aboubak.art>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aboubak-art/img-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/aboubak-art/img-mcp/issues"
  },
  "homepage": "https://aboubak-art.github.io/img-mcp/",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@imgly/background-removal-node": "^1.4.5"
  },
  "peerDependenciesMeta": {
    "@imgly/background-removal-node": {
      "optional": true
    }
  },
  "devDependencies": {
    "@imgly/background-removal-node": "^1.4.3",
    "@types/node": "^22.15.0",
    "gsap": "^3.15.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitepress": "^2.0.0-alpha.17"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
