{
  "name": "img-mcp",
  "version": "1.0.0",
  "description": "An open-source MCP server for AI image generation. Supports Google's Nano Banana models via the Gemini API.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "img-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "image-generation",
    "ai",
    "google",
    "nano-banana",
    "gemini"
  ],
  "author": "Aboubakar Sidik Faha <me@aboubak.art>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidikfaha/img-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/sidikfaha/img-mcp/issues"
  },
  "homepage": "https://sidikfaha.github.io/img-mcp/",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
